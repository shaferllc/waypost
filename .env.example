APP_NAME=Waypost
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the URL you open in the browser (e.g. http://waypost.test with Valet) so Fleet OAuth redirect_uri matches Passport.
APP_URL=http://waypost.test

# OAuth (optional). Set both ID and secret for each provider you want on login/register.
# Register redirect URLs: {APP_URL}/oauth/github/callback and {APP_URL}/oauth/google/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=
# GOOGLE_REDIRECT_URI=

# Central Fleet auth (fleet-auth / Laravel Passport). FLEET_IDP_URL = Fleet Auth app root only (NOT this app’s /oauth/.../callback).
# FLEET_IDP_URL=https://fleet-auth.test
# FLEET_IDP_CLIENT_ID=
# FLEET_IDP_CLIENT_SECRET=
# Optional: omit FLEET_IDP_REDIRECT_URI — fleet/idp-client uses the browser host + /oauth/fleet-auth/callback (must match IdP client).
# FLEET_IDP_REDIRECT_URI="${APP_URL}/oauth/fleet-auth/callback"
# Email/password on this login form validates against Fleet (password grant). From fleet-auth db:seed.
# FLEET_IDP_PASSWORD_CLIENT_ID=
# FLEET_IDP_PASSWORD_CLIENT_SECRET=
# Optional: Eloquent model for user sync (password grant + OAuth callback). Default App\Models\User.
# FLEET_IDP_USER_MODEL=App\\Models\\User

# Default dev user (created by `composer setup` or `php artisan db:seed`):
#   Email:    test@example.com
#   Password: password

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# For live project page updates in the browser, use Reverb: set BROADCAST_CONNECTION=reverb,
# run `php artisan reverb:start`, and fill the variables below (see `php artisan reverb:install`).
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST="localhost"
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Octane (RoadRunner). Run: composer octane  (or php artisan octane:start)
# Binary is downloaded to ./rr (gitignored). Re-install: php artisan octane:install --server=roadrunner
OCTANE_SERVER=roadrunner
# OCTANE_HTTPS=true

# Default X-Waypost-Source hint embedded in downloadable waypost.json (ai, mcp, cursor, …). See config/waypost.php.
# WAYPOST_MANIFEST_X_WAYPOST_SOURCE=ai

# Comma-separated extra agent/client slugs (a-z, digits, _, -) merged with Waypost’s built-in list for headers & agent-events.
# WAYPOST_EXTRA_CLIENT_SOURCES=my_bot,custom_ide

# MCP: set after `npm publish` so Sync uses npx (e.g. @shaferllc/mcp-server@1.0.0). Unset/empty = local mode (copy mcp/waypost-server + npm install).
# WAYPOST_MCP_NPM_PACKAGE=@shaferllc/mcp-server@1.0.0

# Fleet operator API — GET /api/operator/summary (Authorization: Bearer). Same secret as Fleet Console. dply/fleet-operator; unset/empty token → 404 JSON.
# FLEET_OPERATOR_TOKEN=
