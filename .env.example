APP_NAME=Waypost
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL you open in the browser (Valet/Herd: https://waypost.test after `valet secure waypost` / Herd HTTPS). Must match OAuth redirect hosts.
# Use https:// here if Herd/nginx redirects HTTP→HTTPS; Cursor MCP with http:// gets 301 on OPTIONS (no CORS) and shows "Error POSTing".
APP_URL=https://waypost.test

# Optional: public URL for Sync / waypost.json / MCP WAYPOST_BASE_URL when it must differ from APP_URL (usually leave unset).
# WAYPOST_PUBLIC_URL=https://waypost.test

# Streamable HTTP MCP at POST /mcp/waypost. Set false to disable the MCP server (reachable probe + waypost.json still show mcp_enabled).
# WAYPOST_MCP_ENABLED=false

# MCP request logging: defaults to on when APP_ENV=local (see config/waypost.php). Set false to silence.
# WAYPOST_MCP_LOG_REQUESTS=false

# Chromium Private Network Access header for /mcp/* (Cursor → http://*.test). Default true; set false only if you must.
# Chrome may send a PNA-only OPTIONS (no Access-Control-Request-Method); without a 204 answer the MCP POST never runs.
# WAYPOST_MCP_ALLOW_PRIVATE_NETWORK_ACCESS_HEADER=false

# When unset: MCP install URL uses https:// for http://*.test bases (Herd 301 breaks http OPTIONS). Set false for plain-HTTP Docker.
# WAYPOST_MCP_UPGRADE_HTTP_TO_HTTPS=false

# OAuth (optional). Set both ID and secret for each provider you want on login/register.
# Register redirect URLs: {APP_URL}/oauth/github/callback and {APP_URL}/oauth/google/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=
# GOOGLE_REDIRECT_URI=

# Central Fleet auth (fleet-auth / Laravel Passport). FLEET_IDP_URL = Fleet Auth app root only (NOT this app’s /oauth/.../callback).
# Use the same scheme you use in the browser (often https://…); http→https redirects can drop the provisioning Bearer and yield HTTP 401.
# Bootstrap OAuth + provisioning keys: php artisan fleet:idp:configure --url=... --token=... (Fleet Auth needs FLEET_AUTH_CLI_SETUP_TOKEN).
# FLEET_IDP_URL=https://fleet-auth.test
# FLEET_IDP_CLIENT_ID=
# FLEET_IDP_CLIENT_SECRET=
# Optional: omit FLEET_IDP_REDIRECT_URI — shaferllc/fleet-idp-client uses the browser host + /oauth/fleet-auth/callback (must match IdP client).
# FLEET_IDP_REDIRECT_URI="${APP_URL}/oauth/fleet-auth/callback"
# Email/password on this login form validates against Fleet (password grant). From fleet-auth db:seed.
# FLEET_IDP_PASSWORD_CLIENT_ID=
# FLEET_IDP_PASSWORD_CLIENT_SECRET=
# Email code / magic link (Fleet POST /api/email-login/*). Magic link opens this path on Waypost by default.
# FLEET_IDP_EMAIL_LOGIN_MAGIC_PATH=/login/email-magic
# FLEET_IDP_EMAIL_LOGIN_MAGIC_RETURN_URL=
# FLEET_IDP_EMAIL_LOGIN_TIMEOUT=10
# Satellite email sign-in (FleetEmailSignIn + local challenges). Magic route registered by package unless disabled.
# FLEET_IDP_EMAIL_SIGN_IN_REGISTER_MAGIC_ROUTE=true
# FLEET_IDP_EMAIL_SIGN_IN_MAGIC_PATH=login/email-magic
# FLEET_IDP_EMAIL_SIGN_IN_CODE_TTL=10
# FLEET_IDP_EMAIL_SIGN_IN_MAGIC_TTL=30
# FLEET_IDP_EMAIL_SIGN_IN_LOAD_MIGRATIONS=true
# Optional: Eloquent model for user sync (password grant + OAuth callback). Default App\Models\User.
# FLEET_IDP_USER_MODEL=App\\Models\\User
# Package forgot/reset pages: use marketing guest shell (see AppServiceProvider if omitted).
# FLEET_IDP_ACCOUNT_LAYOUT=layouts.guest
# Optional: custom Blade paths (defaults use package views).
# FLEET_IDP_ACCOUNT_VIEW_FORGOT_PASSWORD=auth.forgot-password
# FLEET_IDP_ACCOUNT_VIEW_RESET_PASSWORD=auth.reset-password
# Comma-separated email domains that always get the Fleet reset confirmation step (e.g. admin@fleet.test). Empty = none.
# FLEET_IDP_LIKELY_EMAIL_DOMAINS=fleet.test

# Optional: shaferllc/fleet-idp-client mirrors email sign-ups via Illuminate\Auth\Events\Registered (Admin → Client sites → token).
# Required for forgot-password to email via Fleet Auth API (same Bearer Fleet accepts for POST /api/provisioning/users/...).
# FLEET_AUTH_PROVISIONING_TOKEN=
# FLEET_AUTH_PROVISIONING_URL=
# Local HTTPS errors calling Fleet Auth: FLEET_IDP_PROVISIONING_VERIFY_SSL=false
# FLEET_IDP_PROVISIONING_REQUEST_KEY=_fleet_idp_provisioning_password
# FLEET_IDP_PROVISIONING_PASSWORD_KEYS=_fleet_idp_provisioning_password,password,form.password

# Default dev user (created by `composer setup` or `php artisan db:seed`):
#   Email:    test@example.com
#   Password: password

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# For live project page updates in the browser, use Reverb: set BROADCAST_CONNECTION=reverb,
# run `php artisan reverb:start`, and fill the variables below (see `php artisan reverb:install`).
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST="localhost"
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Octane (RoadRunner). Run: composer octane  (or php artisan octane:start)
# Binary is downloaded to ./rr (gitignored). Re-install: php artisan octane:install --server=roadrunner
OCTANE_SERVER=roadrunner
# OCTANE_HTTPS=true

# Default X-Waypost-Source hint embedded in downloadable waypost.json (ai, mcp, cursor, …). See config/waypost.php.
# WAYPOST_MANIFEST_X_WAYPOST_SOURCE=ai

# Comma-separated extra agent/client slugs (a-z, digits, _, -) merged with Waypost’s built-in list for headers & agent-events.
# WAYPOST_EXTRA_CLIENT_SOURCES=my_bot,custom_ide

# MCP: editors use WAYPOST_API_TOKEN (Bearer) against the app’s HTTPS MCP URL (see project → Sync). WAYPOST_BASE_URL is optional for clients that call the JSON API directly; use APP_URL or WAYPOST_PUBLIC_URL.

# Fleet operator API — GET /api/operator/summary (Authorization: Bearer). Same secret as Fleet Console. dply/fleet-operator; unset/empty token → 404 JSON.
# FLEET_OPERATOR_TOKEN=
